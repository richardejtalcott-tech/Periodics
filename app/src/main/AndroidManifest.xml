<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-feature android:glEsVersion="0x00030000" android:required="true" />
    <application android:allowBackup="true" android:icon="@drawable/ic_atom"
        android:label="Periodic" android:supportsRtl="true" android:theme="@style/AppTheme">
        <activity android:name=".ElementDetailActivity" android:screenOrientation="landscape" />
        <activity android:name=".MainActivity" android:screenOrientation="landscape" />
        <activity android:name=".SplashActivity" android:exported="true" android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
